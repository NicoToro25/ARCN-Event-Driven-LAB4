{
    "name": "Java Spring Event Lab - FIX",
    // Esta imagen ya trae Java 17, Maven y Docker preinstalados
    "image": "mcr.microsoft.com/devcontainers/universal:2",
    "features": {
        // Al usar la imagen universal, NO necesitamos añadir la feature de docker
        // Esto evita el error de instalación que estás viendo
    },
    "forwardPorts": [
        8080,
        8081,
        15672,
        5672
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vmware.vscode-spring-boot",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "remoteUser": "codespace"
}